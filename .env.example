# VoxNews Bharat Environment Configuration
#
# Copy this file to .env.local and fill in the values for your environment.
# NEVER commit .env.local or any file with real secrets to Git.
#
# For local development: Use .env.local (gitignored)
# For staging: Use Vercel environment variables in dashboard
# For production: Use Vercel environment variables in dashboard (with stricter secrets)
#
# Last Updated: May 13, 2026

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Application name (used in logging, emails, etc.)
APP_NAME=VoxNews

# Environment: development, staging, production
APP_ENV=development

# Debug mode (enables verbose logging, error details, etc.)
APP_DEBUG=true

# Log level: error, warn, info, debug, trace
APP_LOG_LEVEL=debug

# Application URL (used for redirects, email links, etc.)
# Local development
APP_URL=http://localhost:3000
# Staging
# APP_URL=https://staging.voxnews.com
# Production
# APP_URL=https://voxnews.com

# API URL (used for frontend → backend API calls)
# This should match where the API is deployed
API_URL=http://localhost:3000
# API_URL=https://staging.voxnews.com
# API_URL=https://voxnews.com

# ============================================================================
# SUPABASE CONFIGURATION (PostgreSQL + Auth + Edge Functions)
# ============================================================================
#
# NOTE: Vite prefixes client-side env vars with VITE_
# These will be accessible in the browser as import.meta.env.VITE_*
#

# Supabase project URL
# Get from: https://supabase.com/dashboard → Your Project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase anonymous/public key (safe to expose)
# Used by the frontend to make authenticated requests
# Get from: https://supabase.com/dashboard → Your Project → Settings → API → anon key
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key (SECRET - NEVER expose publicly)
# Used by backend/edge functions to bypass RLS policies
# Get from: https://supabase.com/dashboard → Your Project → Settings → API → service_role key
# ⚠️ For local development ONLY in .env.local (gitignored)
# ⚠️ For Vercel: Set in Project Settings → Environment Variables (NOT in git)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# CLOUDFLARE CONFIGURATION (R2 Storage + Workers)
# ============================================================================

# Cloudflare account ID
# Get from: https://dash.cloudflare.com/profile/api-tokens → Account ID (left sidebar)
CLOUDFLARE_ACCOUNT_ID=YOUR_ACCOUNT_ID

# Cloudflare API token (for R2 access)
# Get from: https://dash.cloudflare.com/profile/api-tokens → Create Token
# Permissions: Account.Object Storage.Edit (for R2 access)
# ⚠️ NEVER expose publicly
CLOUDFLARE_API_TOKEN=YOUR_API_TOKEN_HERE

# Cloudflare R2 bucket name (for storing cached audio files)
# Create bucket: https://dash.cloudflare.com/account-selector/r2
CLOUDFLARE_R2_BUCKET_NAME=voxnews-audio

# Cloudflare R2 region hint (usually 'auto' for automatic region)
CLOUDFLARE_R2_REGION=auto

# Cloudflare R2 access key ID (alternative to API token)
# Get from: https://dash.cloudflare.com/ → R2 → Manage R2 API tokens
CLOUDFLARE_R2_ACCESS_KEY_ID=

# Cloudflare R2 secret access key (alternative to API token)
# ⚠️ NEVER expose publicly
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# ============================================================================
# SENTRY CONFIGURATION (Error Tracking & Monitoring)
# ============================================================================

# Sentry Data Source Name (DSN)
# Get from: https://sentry.io/settings/YOUR_ORG/projects/voxnews/keys/
# Include the full URL with protocol and path
# Leave empty to disable Sentry in development
SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.sentry.io/YOUR_PROJECT_ID

# Sentry environment (development, staging, production)
# Used to filter and group errors by environment
SENTRY_ENVIRONMENT=development

# Sentry release version (e.g., v0.1.0)
# Used to track errors by release
SENTRY_RELEASE=v0.1.0-dev

# ============================================================================
# FEATURE FLAGS (Enable/Disable Features)
# ============================================================================

# Enable dark mode UI option
ENABLE_DARK_MODE=true

# Enable OCR fallback for scanned PDFs (uses Tesseract.js)
ENABLE_OCR_FALLBACK=true

# Enable user accounts and authentication (v0.2.0 feature)
ENABLE_USER_ACCOUNTS=false

# Enable audio download as MP3 (v0.2.0 feature)
ENABLE_AUDIO_DOWNLOAD=false

# Enable advanced search and filtering (v0.2.0 feature)
ENABLE_ADVANCED_SEARCH=false

# Enable offline mode (requires service worker)
ENABLE_OFFLINE_MODE=false

# ============================================================================
# EMAIL CONFIGURATION (Future: Notifications & Digests)
# ============================================================================

# Email service provider (sendgrid, mailgun, resend, etc.)
# Leave empty to disable email in development
EMAIL_PROVIDER=

# API key for email provider
# Get from your email service provider dashboard
EMAIL_API_KEY=

# Sender email address (notifications, digests, etc.)
EMAIL_FROM_ADDRESS=notifications@voxnews.com

# Sender name
EMAIL_FROM_NAME=VoxNews

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL - Advanced)
# ============================================================================

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database?sslmode=require
# Get from: https://supabase.com/dashboard → Your Project → Settings → Database → Connection String
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres

# Connection pool size (for server-side usage)
DATABASE_POOL_SIZE=20

# Connection timeout in milliseconds
DATABASE_TIMEOUT=30000

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# JWT secret (used for signing tokens locally, if needed)
# Generate with: openssl rand -hex 32
JWT_SECRET=YOUR_JWT_SECRET_KEY_HERE

# CORS allowed origins (comma-separated)
# Specify which domains can access your API
# Local development
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Staging
# CORS_ALLOWED_ORIGINS=https://staging.voxnews.com,https://vercel.app
# Production
# CORS_ALLOWED_ORIGINS=https://voxnews.com

# Rate limiting
# Max requests per minute per IP address
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000  # 1 minute

# ============================================================================
# ANALYTICS & TRACKING (Future)
# ============================================================================

# Google Analytics ID (if using GA)
GOOGLE_ANALYTICS_ID=

# Mixpanel token (if using Mixpanel)
MIXPANEL_TOKEN=

# Posthog API key (if using Posthog)
POSTHOG_API_KEY=

# ============================================================================
# THIRD-PARTY INTEGRATIONS (Future)
# ============================================================================

# Google OAuth2 (for optional social login)
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth2 (for testing/developer access)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================

# Maximum PDF file size (in bytes)
# Default: 100 MB = 104857600 bytes
MAX_PDF_SIZE=104857600

# Allowed file types (comma-separated MIME types)
ALLOWED_FILE_TYPES=application/pdf

# Temporary upload directory (server-side)
UPLOAD_TEMP_DIR=/tmp/voxnews-uploads

# ============================================================================
# PERFORMANCE & OPTIMIZATION
# ============================================================================

# Cache TTL for audio (in seconds)
# Default: 30 days = 2592000 seconds
AUDIO_CACHE_TTL=2592000

# Cache cleanup interval (in seconds)
# How often to remove expired cache entries
# Default: 24 hours = 86400 seconds
CACHE_CLEANUP_INTERVAL=86400

# PDF parsing timeout (in milliseconds)
# Default: 30 seconds = 30000 ms
PDF_PARSING_TIMEOUT=30000

# Audio generation timeout (in milliseconds)
# Default: 10 seconds = 10000 ms
AUDIO_GENERATION_TIMEOUT=10000

# ============================================================================
# DEVELOPMENT TOOLS
# ============================================================================

# Enable API documentation (Swagger/OpenAPI)
ENABLE_API_DOCS=true

# Enable mock data for development
ENABLE_MOCK_DATA=false

# Verbose logging for development
VERBOSE_LOGGING=false

# ============================================================================
# NOTES
# ============================================================================
#
# SECURITY BEST PRACTICES:
# 1. Never commit real secrets to Git
# 2. Use .env.local for development (gitignored)
# 3. Use Vercel Environment Variables for staging/production
# 4. Rotate secrets regularly
# 5. Use separate keys for development, staging, and production
# 6. Enable IP whitelisting in Supabase for sensitive environments
#
# ENVIRONMENT-SPECIFIC SETUP:
#
# LOCAL DEVELOPMENT (.env.local):
#   - Copy this file to .env.local
#   - Fill in SUPABASE_* and CLOUDFLARE_* values
#   - Use localhost URLs
#   - APP_ENV=development
#   - APP_DEBUG=true
#
# STAGING (Vercel Dashboard):
#   - Go to Settings → Environment Variables
#   - Add variables for staging environment
#   - Use staging Supabase project
#   - APP_ENV=staging
#   - APP_DEBUG=false (or use sampled logging)
#
# PRODUCTION (Vercel Dashboard):
#   - Go to Settings → Environment Variables → Production
#   - Use production Supabase project
#   - APP_ENV=production
#   - APP_DEBUG=false
#   - SENTRY_ENVIRONMENT=production
#   - Enable error tracking and monitoring
#
